# =========================================================================
# DeskBoost - .gitignore for .NET, React, Capacitor, and local tooling
# =========================================================================

# Local AI agents and tool state
.agent/
.roo/
.playwright-mcp/
.claude/settings.local.json
**/.claude/settings.local.json

# Environment files
.env
.env.*
**/.env
**/.env.*
!.env.example
!**/.env.example

# Logs
*.log
logs/
**/logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Frontend dependencies and builds
node_modules/
**/node_modules/
dist/
**/dist/
dist-ssr/
**/dist-ssr/
.next/
out/
build/
.eslintcache
.parcel-cache
.cache/

# .NET build artifacts
**/bin/
**/obj/
[Bb]in/
[Oo]bj/
*.user
*.userosscache
*.sln.docstates

# Android and Capacitor build artifacts
**/android/.gradle/
**/android/app/build/
**/android/build/
*.apk
*.aab
*.apks

# Android signing and local service files
*.jks
*.keystore
*.p12
*.pem
keystore.properties
google-services.json

# IDE-local state
.idea/
.vs/
*.suo
*.lscache

# OS files
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
.DS_Store

# Local app settings with real credentials (use appsettings.example.json as template)
**/appsettings.Development.json
**/appsettings.Local.json
**/appsettings.Production.json
