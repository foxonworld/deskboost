{
  "openapi": "3.0.4",
  "info": {
    "title": "DeskBoost.API",
    "version": "1.0"
  },
  "paths": {
    "/api/ai-chat/send": {
      "post": {
        "tags": [
          "AiChat"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SendMessageRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/SendMessageRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/SendMessageRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Diagnosis": {
      "post": {
        "tags": [
          "Diagnosis"
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "Image": {
                    "type": "string",
                    "format": "binary"
                  },
                  "PlantId": {
                    "type": "string",
                    "format": "uuid"
                  }
                }
              },
              "encoding": {
                "Image": {
                  "style": "form"
                },
                "PlantId": {
                  "style": "form"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SendMessageRequest": {
        "type": "object",
        "properties": {
          "plantId": {
            "type": "string",
            "nullable": true
          },
          "userId": {
            "type": "string",
            "nullable": true
          },
          "message": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    }
  },
  "tags": [
    {
      "name": "AiChat"
    },
    {
      "name": "Diagnosis"
    }
  ]
}