# DeskBoost Frontend
# Public client-side values only. Never put Gemini, Plant.id, Cloudinary, JWT, or DB secrets here.

VITE_API_URL=https://<api-host>/api
VITE_GOOGLE_CLIENT_ID=<web-client-id>
VITE_USE_MOCK_AI=false
VITE_USE_MOCK_ADMIN=false
VITE_MOBILE_APP=false
VITE_ROUTER_MODE=browser

# Public GA4 Web Measurement ID. Configure only for the deployed web build.
# Leave unset for local development and Capacitor mobile builds.
VITE_GA_MEASUREMENT_ID=

# Mobile build override example:
# VITE_API_URL=https://<api-host>/api
# VITE_GOOGLE_CLIENT_ID=<web-client-id>
# VITE_MOBILE_APP=true
# VITE_ROUTER_MODE=hash
